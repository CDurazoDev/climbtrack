{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=YOUR_DATABASE;Username=YOUR_USER;Password=YOUR_PASSWORD"
  },
  "Auth": {
    "PasswordResetTokenLifetimeMinutes": 30,
    "PasswordResetUrlTemplate": "https://your-frontend/reset-password?token={token}"
  },
  "Email": {
    "FromAddress": "CHANGE_ME@example.com",
    "FromName": "ClimbTrack",
    "Smtp": {
      "Host": "CHANGE_ME",
      "Port": 587,
      "Username": "CHANGE_ME",
      "Password": "CHANGE_ME",
      "EnableSsl": true
    }
  },
  "StructuredLogging": {
    "RetainedFileCountLimit": 7,
    "FileSizeLimitMb": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
