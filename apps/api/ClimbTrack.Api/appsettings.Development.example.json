{
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=YOUR_DATABASE;Username=YOUR_USER;Password=YOUR_PASSWORD"
  },
  "StructuredLogging": {
    "RetainedFileCountLimit": 7,
    "FileSizeLimitMb": 50
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_A_LONG_RANDOM_SECRET",
    "Issuer": "climbtrack-api",
    "Audience": "climbtrack-app"
  },
  "Auth": {
    "PasswordResetTokenLifetimeMinutes": 30,
    "PasswordResetUrlTemplate": "https://localhost:3000/reset-password?token={token}"
  },
  "Email": {
    "FromAddress": "no-reply@climbtrack.local",
    "FromName": "ClimbTrack",
    "Smtp": {
      "Host": "smtp.local",
      "Port": 587,
      "Username": "your_user",
      "Password": "your_password",
      "EnableSsl": true
    }
  }
}
